      "output_type": "None",
      "error_cases": [],
      "preconditions": [],
      "postconditions": [
        "ctx.obj is a dict",
        "ctx.obj['config'] contains loaded SentinelConfig",
        "ctx.obj['config_path'] contains Path or None"
