  "functions": [
    {
      "name": "load_config",
      "description": "Load sentinel.yaml from the given path, cwd, or defaults. Search order: explicit path, ./sentinel.yaml, ~/.sentinel/sentinel.yaml. Returns default config if no file found.",
      "inputs": [
        {
          "name": "path",
          "type_ref": "Path | None",
          "required": false,
          "default": "None",
          "description": "Optional explicit path to sentinel.yaml file",
          "validators": []
        }
      ],
      "output_type": "SentinelConfig",
      "error_cases": [
        {
          "name": "file_read_error",
          "condition": "File exists but cannot be read",
          "error_type": "Exception",
          "error_data": {
            "handling": "Caught, logged as warning, continues to next candidate"
          }
        },
        {
          "name": "yaml_parse_error",
          "condition": "YAML file is malformed",
          "error_type": "yaml.YAMLError",
          "error_data": {
            "handling": "Caught, logged as warning, continues to next candidate"
          }
        },
        {
          "name": "validation_error",
          "condition": "YAML data fails Pydantic validation",
          "error_type": "pydantic.ValidationError",
          "error_data": {
            "handling": "Caught, logged as warning, continues to next candidate"
          }
        }
      ],
      "preconditions": [],
      "postconditions": [
        "Returns a valid SentinelConfig instance",
        "If no config file is found or all loads fail, returns default SentinelConfig()",
        "If a valid config file is found, returns validated config from that file"
      ],
      "idempotent": true,
      "side_effects": [
        "Reads files from filesystem",
        "Logs warnings when config file loading fails"
      ],
      "structured_side_effects": [
        {
          "kind": "reads_file",
          "target": "sentinel.yaml (from path, cwd, or ~/.sentinel/)",
          "description": "Attempts to read YAML configuration from filesystem in search order"
        },
        {
          "kind": "logging",
          "target": "logger.warning",
          "description": "Logs warning when a config file exists but fails to load or validate"
        }
      ],
      "performance_budget": null
    }
  ],
  "dependencies": [
    "pathlib",
    "logging",
    "typing",
    "yaml",
    "pydantic"
  ],
  "dependency_contracts": {
    "pathlib": [
      "Path"
    ],
    "logging": [
      "getLogger"
    ],
    "typing": [
      "Literal"
    ],
    "yaml": [
      "safe_load"
    ],
    "pydantic": [
      "BaseModel",
      "Field"
    ]
  },
  "invariants": [
    "Default configuration is always valid and can be instantiated without parameters",
    "All Pydantic models have default values for all fields",
    "Config search order is deterministic: explicit path -> ./sentinel.yaml -> ~/.sentinel/sentinel.yaml",
    "First successfully loaded config file wins; subsequent candidates are not checked",
    "If all candidates fail or no files exist, default SentinelConfig is returned"
  ],
  "requires": [],
  "processing_register": "",
  "data_access": {
    "reads": [
      "filesystem"
    ],
    "writes": [],
    "rationale": "Reads YAML configuration files from filesystem. No write operations performed.",
    "side_effects": [
      {
        "type": "file_read",
        "classification": "configuration",
        "fields": [
          "sentinel.yaml"
        ],
        "rationale": "Reads configuration file to load application settings"
      },
      {
        "type": "logging",
